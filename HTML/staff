<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Staff Login</title>
    <style>
        /* Base Body Styles */
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f4f6f8; 
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        /* Login Card Container */
        .login-card {
            background: #ffffff;
            padding: 40px 30px;
            border-radius: 8px;
            border: 1px solid #e5e7eb;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
            width: 100%;
            max-width: 380px;
            box-sizing: border-box;
        }

        /* NEW: Staff Logo Image Styling */
        .staff-logo {
            width: 140px; /* Made slightly larger than the old box so the logo text is readable */
            height: auto;
            display: block;
            margin: 0 auto 20px auto;
            object-fit: contain;
        }

        /* Headings */
        .login-card h2 {
            text-align: center;
            margin: 0 0 30px 0;
            color: #111827;
            font-size: 22px;
        }

        /* Form Elements */
        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            text-align: left;
            margin-bottom: 8px;
            color: #6b7280;
            font-size: 13px;
            font-weight: bold;
        }

        .form-group input {
            width: 100%;
            padding: 12px;
            border: 1px solid #d1d5db;
            background-color: #f9fafb;
            border-radius: 4px;
            font-size: 14px;
            color: #374151;
            box-sizing: border-box; 
            transition: border-color 0.2s;
        }

        .form-group input:focus {
            outline: none;
            border-color: #9ca3af;
            background-color: #ffffff;
        }

        /* Login Button */
        .login-btn {
            width: 100%;
            padding: 12px;
            background-color: #e5e7eb;
            color: #111827;
            border: 1px solid #d1d5db;
            border-radius: 4px;
            font-size: 15px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 10px;
            transition: background-color 0.2s;
        }

        .login-btn:hover {
            background-color: #d1d5db;
        }

        /* Footer Text */
        .forgot-password {
            text-align: center;
            margin-top: 25px;
            font-size: 13px;
            color: #9ca3af;
        }
    </style>
</head>
<body>

    <div class="login-card">
        
        <img src="logo.jpg" alt="PLP Health Services Logo" class="staff-logo">

        <h2>Staff Login</h2>

        <form action="#" method="POST">
            <div class="form-group">
                <label for="username">Username</label>
                <input type="text" id="username" name="username" placeholder="Enter your username" required>
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="••••••••" required>
            </div>

            <button type="submit" class="login-btn">Login</button>
        </form>

        <div class="forgot-password">
            Forgot password? Contact IT Support.
        </div>
    </div>

</body>
</html>
